</div>

<!-- ============ WIZARD (treinamento guiado de agentes) ============ -->
<div class="wizard" id="wizard" role="dialog" aria-modal="true" aria-labelledby="wizard-question-text" aria-hidden="true">
  <header class="wizard-header">
    <button class="wizard-close" type="button" id="wizard-close" aria-label="Fechar treinamento">
      <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 3l-5 5 5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="wizard-progress" aria-live="polite">
      <div class="wizard-progress-track"><div class="wizard-progress-fill" id="wizard-progress-fill"></div></div>
      <span class="wizard-progress-text" id="wizard-progress-text">1 de 13</span>
    </div>
    <button class="wizard-skip" type="button" id="wizard-skip">Pular</button>
  </header>
  <main class="wizard-stage">
    <div class="wizard-card" id="wizard-card"></div>
  </main>
</div>

<script src="main.js"></script>

</body>
</html>
