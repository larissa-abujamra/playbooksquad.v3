        <!-- ETAPA 4 -->
        <div class="stage" id="stage-4">
          <div class="stage-head">
            <span class="stage-num">Etapa 04</span>
            <span class="stage-title">Ative o piloto automático</span>
            <span class="stage-tags tags">
